# ============================================
# CEREBRO v7 — Environment Variables
# Copy to .env and fill in your values
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key

# SerpAPI (keyword research)
SERPAPI_KEY=your-serpapi-key

# Email (Resend)
RESEND_API_KEY=re_your-key
EMAIL_FROM=carlos@dolarafuera.co

# Budget Control
DAILY_BUDGET_USD=30.0

# Domains
PRIMARY_DOMAIN=dolarafuera.co

# Next.js
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feature Flags (Sprint 1: all false)
ENABLE_AUTO_PUBLISH=false
ENABLE_DEMAND_ENGINE=false
ENABLE_AUTOLOOP=false
ENABLE_SOCIAL_ENGINE=false
